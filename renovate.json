{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "mode": "full",
  "baseBranchPatterns": [
    "trunk"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["before 6am every weekday"],
  "prConcurrentLimit": 7,
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "rangeStrategy": "pin",
  "automerge": false,
  "minimumReleaseAge": "3 days",
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "automerge": true
  },
  "commitMessagePrefix": "^ E(deps)",
  "packageRules": [
    {
      "groupName": "Java",
      "matchManagers": ["gradle", "maven"],
      "groupSlug": "java"
    },
    {
      "groupName": "Ktor",
      "matchPackagePatterns": ["^io\\.ktor:"],
      "groupSlug": "ktor"
    }
  ]
}
